#!/bin/sh
# Session entrypoint launched by cage (which is launched by greetd).
export XDG_SESSION_TYPE=wayland
# Use XWayland backend to avoid GTK Wayland protocol errors under Cage
export GDK_BACKEND=x11
if [ -f /etc/myos/onboarded ] || [ -f /etc/myos/live ]; then
    exec myos-shell
fi
exec myos-shell --onboarding
